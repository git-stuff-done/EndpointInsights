<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <property name="LOG_FILE" value="${LOG_FILE:-${LOG_TEMP:-${java.io.tmpdir:-/tmp}}/spring.log}"/>
    <property name="LOG_FILE_MAX_SIZE" value="${LOG_FILE_MAX_SIZE:-10MB}"/>
    <property name="LOG_FILE_MAX_HISTORY" value="${LOG_FILE_MAX_HISTORY:-30}"/>
    <property name="LOG_LEVEL_ROOT" value="${LOG_LEVEL_ROOT:-INFO}"/>
    <property name="LOG_LEVEL_SPRING" value="${LOG_LEVEL_SPRING:-INFO}"/>
    <property name="LOG_LEVEL_APP" value="${LOG_LEVEL_APP:-INFO}"/>
    <property name="LOG_LEVEL_JPA" value="${LOG_LEVEL_JPA:-WARN}"/>
    <property name="LOG_LEVEL_SQL" value="${LOG_LEVEL_SQL:-WARN}"/>
    <property name="LOG_PATTERN" value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n"/>

    <!-- Console Appender -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- File Appender with Rolling Policy -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_FILE}</file>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_FILE}.%d{yyyy-MM-dd}.%i.gz</fileNamePattern>
            <maxFileSize>${LOG_FILE_MAX_SIZE}</maxFileSize>
            <maxHistory>${LOG_FILE_MAX_HISTORY}</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!-- Async Appender for better performance -->
    <appender name="ASYNC_FILE" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>512</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <appender-ref ref="FILE"/>
    </appender>

    <!-- Application-specific loggers -->
    <logger name="com.vsp.endpointinsightsapi" level="${LOG_LEVEL_APP}"/>
    <logger name="com.vsp.endpointinsightsapi.aspects.LogAspect" level="${LOG_LEVEL_APP}"/>
    <logger name="com.vsp.endpointinsightsapi.service" level="${LOG_LEVEL_APP}"/>
    <logger name="com.vsp.endpointinsightsapi.controller" level="${LOG_LEVEL_APP}"/>
    <logger name="com.vsp.endpointinsightsapi.repository" level="${LOG_LEVEL_APP}"/>

    <!-- Spring Framework loggers -->
    <logger name="org.springframework" level="${LOG_LEVEL_SPRING}"/>
    <logger name="org.springframework.security" level="${LOG_LEVEL_SPRING}"/>
    <logger name="org.springframework.boot" level="${LOG_LEVEL_SPRING}"/>

    <!-- Database and JPA loggers -->
    <logger name="org.hibernate" level="${LOG_LEVEL_JPA}"/>
    <logger name="org.hibernate.SQL" level="${LOG_LEVEL_SQL}"/>
    <logger name="org.hibernate.type.descriptor.sql.BasicBinder" level="${LOG_LEVEL_SQL}"/>
    <logger name="org.springframework.data.jpa" level="${LOG_LEVEL_JPA}"/>

    <!-- Root Logger -->
    <root level="${LOG_LEVEL_ROOT}">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="ASYNC_FILE"/>
    </root>

    <!-- Spring Profiles -->
    <springProfile name="dev">
        <root level="DEBUG">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="ASYNC_FILE"/>
        </root>
        <logger name="com.vsp.endpointinsightsapi" level="DEBUG"/>
    </springProfile>

    <springProfile name="prod">
        <root level="WARN">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="ASYNC_FILE"/>
        </root>
        <logger name="com.vsp.endpointinsightsapi" level="INFO"/>
    </springProfile>

    <springProfile name="test">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
        <logger name="com.vsp.endpointinsightsapi" level="DEBUG"/>
    </springProfile>

</configuration>
